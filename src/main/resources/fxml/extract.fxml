<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.blindwatermark.controller.ExtractController"
      styleClass="page-container" spacing="0">

    <VBox styleClass="page-header">
        <Label text="提取水印" styleClass="page-title"/>
        <Label text="从含水印图片中提取文本水印" styleClass="page-description"/>
    </VBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

            <TitledPane text="提取设置" collapsible="false" styleClass="card-pane">
                <VBox styleClass="card-section">
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="72" prefWidth="72"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="解密密码" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <TextField fx:id="txtPassword" promptText="留空表示无密码" styleClass="input-field"
                                   HBox.hgrow="ALWAYS"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    </GridPane>
                </VBox>
            </TitledPane>

            <TitledPane text="含水印图片" collapsible="false" styleClass="card-pane">
                <VBox styleClass="card-section">
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="72" prefWidth="72"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="文件路径" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <TextField fx:id="txtSourcePath" promptText="选择含水印的图片" editable="false"
                                       HBox.hgrow="ALWAYS" styleClass="input-field"/>
                            <Button fx:id="btnChooseSource" text="选择图片" onAction="#onChooseSource"
                                    styleClass="secondary-button"/>
                        </HBox>
                    </GridPane>
                </VBox>
            </TitledPane>

            <HBox styleClass="action-bar" spacing="14">
                <Button fx:id="btnExtract" text="开始提取" onAction="#onExtract"
                        styleClass="primary-button" prefWidth="140" prefHeight="40"/>
                <ProgressBar fx:id="progressBar" prefWidth="300" progress="0" HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text="" styleClass="status-label"/>
            </HBox>

            <TitledPane text="提取结果" collapsible="false" styleClass="card-pane">
                <VBox styleClass="card-section" spacing="12">
                    <Label fx:id="lblResult" text="" styleClass="result-label"/>
                    <TextArea fx:id="txtResultText" editable="false" wrapText="true" prefRowCount="5"
                              promptText="提取到的水印文本将在此显示" styleClass="text-area"/>
                </VBox>
            </TitledPane>

        </VBox>
    </ScrollPane>
</VBox>
