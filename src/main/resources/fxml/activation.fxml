<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.blindwatermark.controller.ActivationController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="root-pane">

    <VBox styleClass="page-container" spacing="0">

        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

            <TitledPane text="当前状态" collapsible="false" styleClass="card-pane">
                <VBox styleClass="card-section">
                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints minWidth="72" prefWidth="72"/>
                            <ColumnConstraints minWidth="200" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="激活状态" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <Label fx:id="lblActivationStatus" text="检查中..." GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="机器码" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label fx:id="lblMachineCode" text="" styleClass="monospace-text"/>
                            <Button fx:id="btnCopyMachineCode" text="复制" onAction="#onCopyMachineCode"
                                    styleClass="small-button"/>
                        </HBox>

                        <Label text="授权码" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                        <Label fx:id="lblLicenseKey" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="授权类型" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
                        <Label fx:id="lblLicenseType" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="过期时间" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="form-label"/>
                        <Label fx:id="lblExpireTime" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </GridPane>
                </VBox>
            </TitledPane>

            <TitledPane fx:id="activationPane" text="激活方式" collapsible="false" styleClass="card-pane">
                <TabPane fx:id="tabPane" prefHeight="220">
                    <Tab fx:id="tabOnline" text="在线激活" closable="false">
                        <VBox styleClass="card-section" spacing="14">
                            <Label text="输入授权码，在线验证并激活软件:" styleClass="form-hint"/>
                            <GridPane hgap="12" vgap="10">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="72" prefWidth="72"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="授权码" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                                <TextField fx:id="txtOnlineLicenseKey" promptText="XXXX-XXXX-XXXX-XXXX"
                                           styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            </GridPane>
                            <HBox>
                                <Button fx:id="btnOnlineActivate" text="在线激活" onAction="#onOnlineActivate"
                                        styleClass="primary-button" prefWidth="130"/>
                            </HBox>
                        </VBox>
                    </Tab>
                    <Tab fx:id="tabOffline" text="离线激活" closable="false">
                        <VBox styleClass="card-section" spacing="14">
                            <Label text="当前设备机器码 (提供给授权方获取离线授权码):" styleClass="form-hint"/>
                            <Label fx:id="lblOfflineMachineCode" text="" styleClass="monospace-text"/>
                            <GridPane hgap="12" vgap="10">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="72" prefWidth="72"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="授权码" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                                <TextField fx:id="txtOfflineLicenseKey" promptText="输入离线授权码"
                                           styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            </GridPane>
                            <HBox>
                                <Button fx:id="btnOfflineActivate" text="离线激活" onAction="#onOfflineActivate"
                                        styleClass="primary-button" prefWidth="130"/>
                            </HBox>
                        </VBox>
                    </Tab>
                </TabPane>
            </TitledPane>

            <TitledPane text="应用信息" collapsible="false" styleClass="card-pane">
                <VBox styleClass="card-section" spacing="10" alignment="CENTER">
                    <HBox fx:id="copyrightBox" alignment="CENTER" spacing="4"/>
                    <Label fx:id="lblAuthor" text="" styleClass="form-hint"/>
                    <Label fx:id="lblVersion" text="" styleClass="form-hint"/>
                </VBox>
            </TitledPane>

        </VBox>
    </VBox>
</ScrollPane>
